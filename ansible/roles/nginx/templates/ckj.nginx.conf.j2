# ============================================
# nginx config para CKJ - Sistema de Almacén
# Proxy inverso: Angular (frontend) + Express (API)
# ============================================

upstream ckj_api {
    server 127.0.0.1:{{ backend_port }};
}

server {
    listen 80;
    server_name {{ nginx_server_name }};
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name {{ nginx_server_name }};

    # ── Certificados SSL (Let's Encrypt) ──
    ssl_certificate     {{ ssl_cert_path }};
    ssl_certificate_key {{ ssl_key_path }};
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # ── Frontend Angular (archivos estáticos) ──
    root {{ frontend_dir }};
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # ── API Backend (proxy a Express) ──
    location /api/ {
        proxy_pass http://ckj_api;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # ── Endpoints adicionales del backend ──
    location ~ ^/(materiales|movimientos|dashboard) {
        proxy_pass http://ckj_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # ── Archivos subidos (comprobantes) ──
    location /uploads/ {
        alias {{ uploads_dir }}/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # ── Seguridad ──
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    location ~ /(node_modules|\.git|src) {
        deny all;
        return 404;
    }

    # ── Logs ──
    access_log /var/log/nginx/{{ app_name }}_access.log;
    error_log  /var/log/nginx/{{ app_name }}_error.log;
}
